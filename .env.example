# ─────────────────────────────────────────────────────────────────────────────
# Browserr - example environment.
# Copy to `.env` and fill in. Env values SEED the DB on first boot and act as
# defaults thereafter. GUI settings override env unless LOCK_CONFIG=true.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
PORT=3000
PUBLIC_URL=http://localhost:3000          # external URL of Browserr itself (absolute links)
TZ=Europe/Warsaw
LOCK_CONFIG=false                          # true => env is authoritative, GUI is read-only

# --- TMDB --- (supply ONE of these)
TMDB_API_KEY=                              # v3 key  (or)
TMDB_ACCESS_TOKEN=                         # v4 bearer token
TMDB_LANGUAGE=en-US

# --- Seerr ---
SEERR_INTERNAL_URL=http://seerr:5055       # server-to-server API calls (Docker network)
SEERR_EXTERNAL_URL=http://localhost:5055   # browser redirects for requesting
SEERR_API_KEY=
SEERR_REQUEST_MODE=redirect                # redirect | proxy

# --- Region & services ---
DEFAULT_REGION=US                          # ISO 3166-1 alpha-2
DEFAULT_SERVICES=                          # CSV of TMDB watch-provider IDs (e.g. 8,9,337); empty = all in region
MONETIZATION_TYPES=flatrate                # flatrate,free,ads,rent,buy (CSV)

# --- Auth ---
AUTH_MODE=none                             # none | seerr | basic
SESSION_SECRET=
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# --- Data ---
# Local dev: a relative path under the project. Docker compose overrides this to
# the absolute volume path (sqlite:///data/browserr.db). If the configured path
# isn't writable, Browserr self-heals to ./data.
DATABASE_URL=sqlite://./data/browserr.db
REDIS_URL=                                 # optional

# --- Recommendations ---
ENABLE_RECOMMENDATIONS=true
ENABLE_EMBEDDINGS=false                     # optional semantic recs (sidecar/transformers.js)
RECS_REFRESH_CRON=0 */6 * * *

# --- Feature toggles ---
ENABLE_LIBRARY_RAILS=true                   # "Available now in your library" rails from Seerr
HERO_ROTATE_SECONDS=12

# --- Telemetry ---
# Anonymous daily install heartbeat: a random per-instance id + the Browserr
# version. No IP, user, or content data. Opt out entirely with the flag below.
BROWSERR_TELEMETRY=true
TELEMETRY_URL=                              # override the counter endpoint; empty = project default (set in code)
