{
  "name": "browserr",
  "version": "0.1.3",
  "private": true,
  "description": "A self-hosted, Netflix-style discovery front-end for your media stack, with deep Seerr integration.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:demo": "node scripts/build-demo.mjs",
    "demo:fixtures": "node scripts/gen-demo-fixtures.mjs",
    "screenshots": "node scripts/screenshots.mjs",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@tanstack/react-query": "^5.62.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.3",
    "framer-motion": "^11.15.0",
    "lru-cache": "^11.0.2",
    "lucide-react": "^0.469.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.5.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.20.2"
  }
}
